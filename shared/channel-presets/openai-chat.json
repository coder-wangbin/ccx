{
  "schemaVersion": 1,
  "providers": {
    "deepseek": {
      "reasoningParamStyle": "reasoning",
      "noVision": true
    },
    "mimo": {
      "reasoningParamStyle": "thinking",
      "noVisionModels": ["mimo-v2.5-pro"],
      "visionFallbackModel": "mimo-v2.5",
      "rateLimitRpm": 80
    },
    "compshare": {
      "reasoningParamStyle": "reasoning",
      "noVisionModels": ["glm-5.2", "deepseek-v4-flash"],
      "visionFallbackModel": "MiniMax-M2.7"
    },
    "runapi": {},
    "unity2": {},
    "openrouter": {},
    "sensenova": {
      "normalizeNonstandardChatRoles": true,
      "noVisionModels": ["glm-5.2", "deepseek-v4-flash"],
      "visionFallbackModel": "sensenova-6.7-flash-lite"
    },
    "modelscope": {
      "normalizeNonstandardChatRoles": true
    },
    "minimax": {},
    "dashscope": {},
    "opencode-zen": {
      "modelMapping": {
        "codex": "deepseek-v4-flash",
        "gpt": "glm-5.2",
        "mini": "deepseek-v4-flash"
      },
      "reasoningMapping": {
        "codex": "high",
        "gpt": "max",
        "mini": "high"
      },
      "reasoningParamStyle": "reasoning",
      "authHeader": "bearer",
      "normalizeNonstandardChatRoles": true,
      "noVisionModels": ["glm-5.2", "deepseek-v4-flash"],
      "visionFallbackModel": "minimax-m3"
    },
    "opencode-go": {
      "modelMapping": {
        "codex": "deepseek-v4-flash",
        "gpt": "glm-5.2",
        "mini": "deepseek-v4-flash"
      },
      "reasoningMapping": {
        "codex": "high",
        "gpt": "max",
        "mini": "high"
      },
      "reasoningParamStyle": "reasoning",
      "authHeader": "bearer",
      "normalizeNonstandardChatRoles": true,
      "noVisionModels": ["glm-5.2", "deepseek-v4-flash"],
      "visionFallbackModel": "minimax-m3"
    },
    "volc-ark": {
      "normalizeNonstandardChatRoles": true
    },
    "qianfan": {
      "normalizeNonstandardChatRoles": true
    },
    "xfyun": {
      "modelMapping": {
        "codex": "astron-code-latest",
        "gpt": "astron-code-latest",
        "mini": "astron-code-latest"
      },
      "normalizeNonstandardChatRoles": true
    }
  }
