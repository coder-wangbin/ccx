<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="ccx-desktop.exe"
        Arguments=""
        InstallLocation="C:\Program Files\CCX\CCX Desktop">
    </Installer>
    <PackageInformation
        PackageName="CCX.Desktop"
        PackageDisplayName="CCX Desktop"
        PublisherName="CN=CCX"
        PublisherDisplayName="CCX"
        Version="0.1.0.0"
        PackageDescription="Desktop shell for the CCX core gateway service.">
        <Capabilities>
            <Capability Name="runFullTrust" />
        </Capabilities>
        <Applications>
            <Application
                Id="CCXDesktop"
                Description="Desktop shell for the CCX core gateway service."
                DisplayName="CCX Desktop"
                ExecutableName="ccx-desktop.exe"
                EntryPoint="Windows.FullTrustApplication">
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>CCX Desktop</DisplayName>
            <PublisherDisplayName>CCX</PublisherDisplayName>
            <Description>Desktop shell for the CCX core gateway service.</Description>
            <Logo>Assets\StoreLogo.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="ccx-desktop.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
